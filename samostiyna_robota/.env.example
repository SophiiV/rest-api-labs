# Приклад файлу з секретами. СПРАВЖНІЙ .env НЕ комітимо (він у .gitignore).
# Скопіюй у .env та постав свої значення або виставляй прямо в Render Dashboard.

# Connection string до MongoDB Atlas (безкоштовний cluster M0).
# Формат: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://libraryuser:CHANGE_ME@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Назва бази даних (motor сам створить, якщо ще нема)
MONGO_DB_NAME=library_db
